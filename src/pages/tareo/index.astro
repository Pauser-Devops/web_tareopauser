---
import Layout from "../../layouts/Layout.astro";
import { MESES } from "../../lib/supabase";

const anios = [2024, 2025, 2026];
const anioParam = Astro.url.searchParams.get("anio");

// Usar fecha real del sistema (no hardcodeado a 2026)
const now = new Date();
const anioHoy = now.getFullYear();
const mesActualHoy = now.getMonth() + 1;

const anioActual = anioParam ? parseInt(anioParam) : anioHoy;

// Calcular si cada mes es pasado/actual o futuro — usando la fecha real
const mesesData = Array.from({ length: 12 }, (_, i) => {
    const m = i + 1;
    const esPasadoOActual =
        anioActual < anioHoy || (anioActual === anioHoy && m <= mesActualHoy);
    return { m, esPasadoOActual };
});
---

<Layout title="Planillas" breadcrumb="Lista de Tareos">
    <div class="page-header">
        <div class="page-header__text">
            <h2>Planillas de Tareo</h2>
            <p>Gestiona los tareos mensuales de PAUSER DISTRIBUCIONES S.A.C.</p>
        </div>
        <div class="page-header__actions">
            <select
                class="form-input"
                id="sel-anio"
                style="padding:7px 12px;width:120px"
            >
                {
                    anios.map((a) => (
                        <option value={String(a)} selected={a === anioActual}>
                            {a}
                        </option>
                    ))
                }
            </select>
        </div>
    </div>

    <div
        style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:14px"
    >
        {
            mesesData.map(({ m, esPasadoOActual }) => (
                <a
                    href="#"
                    data-anio={anioActual}
                    data-mes={m}
                    class="card tareo-card"
                    style={`text-decoration:none;display:block;transition:border-color 0.15s;${!esPasadoOActual ? "opacity:0.4;cursor:default;pointer-events:none" : "cursor:pointer"}`}
                >
                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
                        <div style="font-size:16px;font-weight:700">
                            {MESES[m]}
                        </div>
                        <span class="badge badge--gray" id={`mes-badge-${m}`}>
                            Pendiente
                        </span>
                    </div>
                    <div style="font-size:12px;color:var(--color-text-muted)">
                        {anioActual}
                    </div>
                </a>
            ))
        }
    </div>
</Layout>

<script>
    // @ts-nocheck

    // ── Guard de sesión ────────────────────────────────────────────────────────
    const authRaw = window.sessionStorage.getItem("pt_auth");
    if (!authRaw) {
        window.location.href = "/login";
    }

    let user = null;
    try {
        user = JSON.parse(authRaw);
    } catch (e) {}
    if (!user) {
        window.location.href = "/login";
    }

    const rol = user?.rol ?? "analista";
    const userId = user?.id ?? null;

    // ── Selector de año ────────────────────────────────────────────────────────
    const sel = document.getElementById("sel-anio");
    sel?.addEventListener("change", () => {
        window.location.href = `/tareo?anio=${sel.value}`;
    });

    // ── Navegar al hacer click en tarjeta ──────────────────────────────────────
    // JEFE: guardar el mes/año en pt_periodo antes de navegar, para que
    //       TareoJefePanel lo recoja y muestre el mes correcto.
    // ANALISTA: ir directamente a la ruta dinámica /tareo/analista/{anio}/{mes}
    const cards = document.querySelectorAll(".tareo-card");
    cards.forEach((c) => {
        c.addEventListener("click", (e) => {
            const anio = parseInt(c.getAttribute("data-anio"));
            const mes = parseInt(c.getAttribute("data-mes"));
            if (anio && mes) {
                e.preventDefault();
                if (rol === "jefe") {
                    // Persistir periodo para que el panel del Jefe lo use
                    window.sessionStorage.setItem(
                        "pt_periodo",
                        JSON.stringify({ anio, mes }),
                    );
                    window.location.href = "/tareo/jefe";
                } else {
                    const mesPadded = String(mes).padStart(2, "0");
                    window.location.href = `/tareo/analista/${anio}/${mesPadded}`;
                }
            }
        });
    });

    // ── Cargar estados reales de tareos desde Supabase ─────────────────────────
    const sbUrl = document
        .querySelector('meta[name="sb-url"]')
        ?.getAttribute("content");
    const sbKey = document
        .querySelector('meta[name="sb-key"]')
        ?.getAttribute("content");
    const anioSel = Number(sel?.value ?? new Date().getFullYear());

    function aplicarBadge(badge, estado) {
        if (!badge) return;
        const mapa = {
            cerrado: { texto: "Cerrado", cls: "badge--green" },
            en_revision: { texto: "En Revisión", cls: "badge--orange" },
            obs_levantadas: { texto: "Obs. Levantadas", cls: "badge--blue" },
            borrador: { texto: "Borrador", cls: "badge--yellow" },
            concretado: { texto: "Concretado", cls: "badge--green" },
        };
        const info = mapa[estado] ?? { texto: "Pendiente", cls: "badge--gray" };
        badge.textContent = info.texto;
        badge.className = `badge ${info.cls}`;
    }

    if (sbUrl && sbKey && !sbKey.startsWith("REEMPLAZAR")) {
        if (rol === "jefe") {
            fetch(
                `${sbUrl}/rest/v1/tareo_maestro?anio=eq.${anioSel}&select=mes,estado`,
                {
                    headers: {
                        apikey: sbKey,
                        Authorization: `Bearer ${sbKey}`,
                    },
                },
            )
                .then((r) => r.json())
                .then((data) =>
                    data.forEach(({ mes, estado }) =>
                        aplicarBadge(
                            document.getElementById(`mes-badge-${mes}`),
                            estado,
                        ),
                    ),
                )
                .catch(() => {});
        } else if (userId) {
            fetch(
                `${sbUrl}/rest/v1/tareos_analista?analista_id=eq.${userId}&anio=eq.${anioSel}&select=mes,estado`,
                {
                    headers: {
                        apikey: sbKey,
                        Authorization: `Bearer ${sbKey}`,
                    },
                },
            )
                .then((r) => r.json())
                .then((data) =>
                    data.forEach(({ mes, estado }) =>
                        aplicarBadge(
                            document.getElementById(`mes-badge-${mes}`),
                            estado,
                        ),
                    ),
                )
                .catch(() => {});
        }
    }
</script>
