---
import Layout from "../layouts/Layout.astro";
import DashboardStats from "../components/tareo/DashboardStats";
import DashboardRecentTareos from "../components/tareo/DashboardRecentTareos";
import { MESES } from "../lib/supabase";

// Se inicializa con valores por defecto del servidor,
// pero en React (DashboardStats client:load) se hidratará con la info del Storage si existe.
const anioActual = new Date().getFullYear();
const mesActual = new Date().getMonth() + 1;
---

<Layout title="Dashboard" breadcrumb="Inicio">
  <!-- Header -->
  <div class="page-header">
    <div class="page-header__text">
      <h2>Bienvenido al Sistema de Tareo</h2>
      <p id="dashboard-periodo-texto">
        Planilla laboral — PAUSER DISTRIBUCIONES S.A.C. | {MESES[mesActual]}
        {anioActual}
      </p>
    </div>
    <div class="page-header__actions">
      <a
        id="btn-dashboard-tareo"
        style="display: none;"
        class="btn btn--primary"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"
          ></path>
          <polyline points="14 2 14 8 20 8"></polyline>
        </svg>
        Tareo del mes
      </a>
    </div>
  </div>

  <DashboardStats client:load anio={anioActual} mes={mesActual} />

  <!-- Tareos recientes -->
  <div class="card">
    <div class="card__header">
      <div class="card__title">Tareos del Año {anioActual}</div>
      <a
        href="/tareo"
        class="btn btn--ghost"
        style="font-size:12px;padding:5px 10px">Ver todos →</a
      >
    </div>
    <DashboardRecentTareos client:load anioActual={anioActual} />
  </div>

  <!-- Info SUNAT -->
  <div
    style="margin-top:20px;display:grid;grid-template-columns:1fr 1fr;gap:16px"
  >
    <div class="card">
      <div class="card__header">
        <div class="card__title">Tasas Previsionales Vigentes</div>
      </div>
      <table class="data-table" style="font-size:12px">
        <thead>
          <tr><th>AFP</th><th>Código</th><th>Flujo</th><th>Mixta</th></tr>
        </thead>
        <tbody>
          {
            [
              { n: "PRIMA", t: "PRIMA", f: "12.97%", m: "—" },
              { n: "PROFUTURO", t: "PROFUT", f: "13.06%", m: "11.37%" },
              { n: "INTEGRA", t: "INTEGR", f: "12.92%", m: "11.37%" },
              { n: "HABITAT", t: "HABITAT", f: "12.84%", m: "11.37%" },
              { n: "ONP", t: "ONP", f: "13.00%", m: "—" },
            ].map((a) => (
              <tr>
                <td style="font-weight:600">{a.n}</td>
                <td class="mono">{a.t}</td>
                <td class="text-primary">{a.f}</td>
                <td class="text-muted">{a.m}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <div class="card">
      <div class="card__header">
        <div class="card__title">Aportes del Empleador</div>
      </div>
      <div style="display:flex;flex-direction:column;gap:12px">
        {
          [
            {
              label: "EsSalud",
              pct: "9.00%",
              desc: "Sobre remuneración computable",
            },
            {
              label: "EPS (si aplica)",
              pct: "2.25%",
              desc: "Descuento compensatorio EsSalud",
            },
            {
              label: "SCTR Salud",
              pct: "Variable",
              desc: "Según actividad de riesgo",
            },
            { label: "Vida Ley", pct: "0.53%", desc: "A cargo del trabajador" },
          ].map((r) => (
            <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--color-border)">
              <div>
                <div style="font-weight:600;font-size:13px">{r.label}</div>
                <div class="text-muted" style="font-size:11px">
                  {r.desc}
                </div>
              </div>
              <div class="badge badge--blue">{r.pct}</div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</Layout>

<script>
  // @ts-nocheck
  (function () {
    var raw = window.sessionStorage.getItem("pt_auth");
    if (raw) {
      try {
        var user = JSON.parse(raw);
        var pos = (user.position || "").toUpperCase();
        var btn = document.getElementById("btn-dashboard-tareo");

        // Revisar si hay un periodo global en sessionStorage
        var pAnio = new Date().getFullYear();
        var pMes = new Date().getMonth() + 1;
        var rawPeriodo = window.sessionStorage.getItem("pt_periodo");
        if (rawPeriodo) {
          try {
            var pe = JSON.parse(rawPeriodo);
            pAnio = pe.anio || pAnio;
            pMes = pe.mes || pMes;
          } catch (e) {}
        }

        // Actualizar el texto del periodo en base al sessionStorage
        var mesesArray = [
          "",
          "Enero",
          "Febrero",
          "Marzo",
          "Abril",
          "Mayo",
          "Junio",
          "Julio",
          "Agosto",
          "Septiembre",
          "Octubre",
          "Noviembre",
          "Diciembre",
        ];
        var textoEl = document.getElementById("dashboard-periodo-texto");
        if (textoEl) {
          textoEl.innerHTML =
            "Planilla laboral &mdash; PAUSER DISTRIBUCIONES S.A.C. | " +
            mesesArray[pMes] +
            " " +
            pAnio;
        }

        // Mostrar el botón solo si el cargo incluye "JEFE DE GENTE Y GESTIÓN"
        if (btn && pos.includes("JEFE DE GENTE Y GESTIÓN")) {
          btn.href = "/tareo/maestro";
          btn.style.display = "inline-flex";
        }
      } catch (e) {}
    }
  })();
</script>
