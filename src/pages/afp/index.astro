---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Tasas AFP" breadcrumb="Tasas AFP">
    <div class="page-header">
        <div class="page-header__text">
            <h2>Tasas AFP / ONP</h2>
            <p>Tasas previsionales vigentes — año 2026</p>
        </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px">
        <div class="card">
            <div class="card__header">
                <div class="card__title">AFP — Régimen de Flujo (Regular)</div>
            </div>
            <table class="data-table">
                <thead>
                    <tr>
                        <th>AFP</th>
                        <th>Código</th>
                        <th class="cell-num">Tasa %</th>
                        <th>Neto/Bruto</th>
                    </tr>
                </thead>
                <tbody>
                    {
                        [
                            { n: "PRIMA", c: "PRIMA", t: 12.97 },
                            { n: "PROFUTURO", c: "PROFUT", t: 13.06 },
                            { n: "INTEGRA", c: "INTEGR", t: 12.92 },
                            { n: "HABITAT", c: "HABITAT", t: 12.84 },
                        ].map((a) => (
                            <tr>
                                <td style="font-weight:600">{a.n}</td>
                                <td class="mono">{a.c}</td>
                                <td
                                    class="cell-num text-primary"
                                    style="font-weight:700"
                                >
                                    {a.t.toFixed(2)}%
                                </td>
                                <td>
                                    <span class="badge badge--green">
                                        Flujo puro
                                    </span>
                                </td>
                            </tr>
                        ))
                    }
                </tbody>
            </table>
        </div>

        <div class="card">
            <div class="card__header">
                <div class="card__title">AFP — Régimen Mixto</div>
            </div>
            <table class="data-table">
                <thead>
                    <tr>
                        <th>AFP</th>
                        <th>Código</th>
                        <th class="cell-num">Tasa %</th>
                        <th>Neto/Bruto</th>
                    </tr>
                </thead>
                <tbody>
                    {
                        [
                            { n: "X-PRIMA", c: "X-PRIM", t: 11.37 },
                            { n: "X-PROFUTURO", c: "X-PROF", t: 11.37 },
                            { n: "X-INTEGRA", c: "X-INTE", t: 11.37 },
                            { n: "X- HABITAT", c: "X-HAB", t: 11.37 },
                        ].map((a) => (
                            <tr>
                                <td style="font-weight:600">{a.n}</td>
                                <td class="mono">{a.c}</td>
                                <td
                                    class="cell-num text-warning"
                                    style="font-weight:700"
                                >
                                    {a.t.toFixed(2)}%
                                </td>
                                <td>
                                    <span class="badge badge--yellow">
                                        Mixto
                                    </span>
                                </td>
                            </tr>
                        ))
                    }
                </tbody>
            </table>
        </div>

        <div class="card">
            <div class="card__header">
                <div class="card__title">SNP / ONP</div>
            </div>
            <table class="data-table">
                <thead>
                    <tr
                        ><th>Sistema</th><th>Código</th><th class="cell-num"
                            >Tasa %</th
                        ></tr
                    >
                </thead>
                <tbody>
                    <tr>
                        <td style="font-weight:600"
                            >Sistema Nacional de Pensiones</td
                        >
                        <td class="mono">ONP</td>
                        <td
                            class="cell-num text-primary"
                            style="font-weight:700">13.00%</td
                        >
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="card">
            <div class="card__header">
                <div class="card__title">Aportes del Empleador</div>
            </div>
            <table class="data-table">
                <thead>
                    <tr
                        ><th>Concepto</th><th class="cell-num">Tasa %</th><th
                            >Cargo</th
                        ></tr
                    >
                </thead>
                <tbody>
                    {
                        [
                            { c: "EsSalud", t: "9.00%", cargo: "Empleador" },
                            {
                                c: "EPS (descuento)",
                                t: "2.25%",
                                cargo: "Empleador",
                            },
                            { c: "Vida Ley", t: "0.53%", cargo: "Trabajador" },
                        ].map((r) => (
                            <tr>
                                <td style="font-weight:600">{r.c}</td>
                                <td
                                    class="cell-num text-warning"
                                    style="font-weight:700"
                                >
                                    {r.t}
                                </td>
                                <td>
                                    <span
                                        class={`badge ${r.cargo === "Empleador" ? "badge--blue" : "badge--gray"}`}
                                    >
                                        {r.cargo}
                                    </span>
                                </td>
                            </tr>
                        ))
                    }
                </tbody>
            </table>
        </div>
    </div>
</Layout>
